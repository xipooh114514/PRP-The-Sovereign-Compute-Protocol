使用 pynvml（NVIDIA 官方 NVML Python binding）+ threading 非阻塞記錄，每 500ms 採樣一次。同時計算累積能量（Joules），這正是 PSY 計算的核心

# prp_power_logger.py
import pynvml
import time
import csv
import threading
import datetime
from pathlib import Path

class PRP_PowerLogger:
    def __init__(self, gpu_index=0, log_interval_sec=0.5, log_dir="node01_logs"):
        pynvml.nvmlInit()
        self.handle = pynvml.nvmlDeviceGetHandleByIndex(gpu_index)
        self.log_interval = log_interval_sec
        self.log_dir = Path(log_dir)
        self.log_dir.mkdir(exist_ok=True)
        self.log_file = self.log_dir / f"power_log_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
        self.stop_event = threading.Event()
        self.thread = None
        self.data = []  # 記憶體暫存，最後寫入 CSV

    def _log_loop(self):
        with open(self.log_file, 'w', newline='') as f:
            writer = csv.writer(f)
            writer.writerow(["timestamp", "power_w", "temp_c", "gpu_util_pct", "mem_util_pct", 
                           "clock_sm_mhz", "clock_mem_mhz", "energy_joules_cumulative"])
            
            cumulative_energy = 0.0
            last_time = time.time()
            
            while not self.stop_event.is_set():
                try:
                    power_mw = pynvml.nvmlDeviceGetPowerUsage(self.handle)          # mW
                    temp = pynvml.nvmlDeviceGetTemperature(self.handle, pynvml.NVML_TEMPERATURE_GPU)
                    util = pynvml.nvmlDeviceGetUtilizationRates(self.handle)
                    clocks = pynvml.nvmlDeviceGetClockInfo(self.handle, pynvml.NVML_CLOCK_SM)
                    mem_clocks = pynvml.nvmlDeviceGetClockInfo(self.handle, pynvml.NVML_CLOCK_MEM)
                    
                    now = time.time()
                    delta_t = now - last_time
                    power_w = power_mw / 1000.0
                    cumulative_energy += power_w * delta_t
                    
                    row = [
                        now,
                        round(power_w, 3),
                        temp,
                        util.gpu,
                        util.memory,
                        clocks,
                        mem_clocks,
                        round(cumulative_energy, 2)
                    ]
                    writer.writerow(row)
                    f.flush()  # 即時寫入，斷電也不怕
                    
                    last_time = now
                    time.sleep(self.log_interval)
                except Exception as e:
                    print(f"[PRP Logger Error] {e}")
                    break

    def start(self):
        self.thread = threading.Thread(target=self._log_loop, daemon=True)
        self.thread.start()
        print(f"[PRP] Power logger started → {self.log_file}")

    def stop(self):
        self.stop_event.set()
        if self.thread:
            self.thread.join(timeout=2)
        pynvml.nvmlShutdown()
        print(f"[PRP] Logger stopped. Total energy: {self.data[-1][-1] if self.data else 'N/A'} J")

# 使用範例（直接包在你的 OpenMM 任務外）
if __name__ == "__main__":
    logger = PRP_PowerLogger(gpu_index=0)  # 你的 4070 Ti Super
    logger.start()
    
    # ←←← 在這裡放你的 OpenMM 模擬代碼 ←←←
