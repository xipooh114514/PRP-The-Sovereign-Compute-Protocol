    logger.stop()

ACR 的物理證據核心

先跑 N 次基準 OpenMM 任務（相同分子、相同步數），建立「golden fingerprint」。
# prp_anomaly_detector.py
import pandas as pd
import numpy as np
from scipy.stats import zscore
import json

class PRP_Fingerprint:
    def __init__(self, baseline_csvs: list):
        self.features = ["power_w_mean", "power_w_std", "total_energy_j", 
                        "temp_delta", "gpu_util_mean"]
        self.baseline_stats = {}
        self._build_baseline(baseline_csvs)

    def _build_baseline(self, csv_files):
        all_data = []
        for csv in csv_files:
            df = pd.read_csv(csv)
            stats = {
                "power_w_mean": df["power_w"].mean(),
                "power_w_std": df["power_w"].std(),
                "total_energy_j": df["energy_joules_cumulative"].iloc[-1],
                "temp_delta": df["temp_c"].max() - df["temp_c"].min(),
                "gpu_util_mean": df["gpu_util_pct"].mean(),
            }
            all_data.append(stats)
        
        df_base = pd.DataFrame(all_data)
        for feat in self.features:
            self.baseline_stats[feat] = {
                "mean": df_base[feat].mean(),
                "std": df_base[feat].std()
            }
        print("✅ Baseline built for OpenMM fingerprint")

    def check(self, run_csv: str, threshold_z=3.0) -> dict:
        df = pd.read_csv(run_csv)
        stats = {
            "power_w_mean": df["power_w"].mean(),
            "power_w_std": df["power_w"].std(),
            "total_energy_j": df["energy_joules_cumulative"].iloc[-1],
            "temp_delta": df["temp_c"].max() - df["temp_c"].min(),
            "gpu_util_mean": df["gpu_util_pct"].mean(),
        }
        
        anomalies = {}
        for feat in self.features:
            z = (stats[feat] - self.baseline_stats[feat]["mean"]) / (self.baseline_stats[feat]["std"] + 1e-8)
            if abs(z) > threshold_z:
                anomalies[feat] = {"z_score": round(z, 3), "value": round(stats[feat], 3)}
        
        is_valid = len(anomalies) == 0
        return {
            "valid": is_valid,
            "anomalies": anomalies,
            "summary": stats
        }

# 使用方式
# baseline = PRP_Fingerprint(["baseline1.csv", "baseline2.csv", ...])
# result = baseline.check("node01_run_20250403.csv")
# print(result)
怎麼建立 baseline：
1.  用相同 OpenMM 任務跑 10 次，存 10 個 CSV。
2.  餵給 PRP_Fingerprint 就得到常模。
3.  之後每跑一次新任務就 check()，如果 valid=True 才產生 ACR。
這已經能抓 90% 以上的「偷工減料」（5 分鐘跑完、功耗只有 40W、溫度平坦等明顯異常）。

